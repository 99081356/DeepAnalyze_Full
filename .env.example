# DeepAnalyze Hub Configuration
# Copy this file to .env and customize for your setup.

# Server
PORT=22000
NODE_ENV=development

# PostgreSQL (Hub uses a separate database from Workers)
PG_HOST=localhost
PG_PORT=5433
PG_DATABASE=deepanalyze_hub
PG_USER=deepanalyze_hub
PG_PASSWORD=deepanalyze_hub_dev

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRY=7d

# Worker authentication
WORKER_TOKEN_EXPIRY=30d

# ─── Phase A: JWT RS256 ──────────────────────────────────────────────
# Generate with:
#   openssl genpkey -algorithm RSA -out priv.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -pubout -in priv.pem -out pub.pem
# Leave paths empty to keep HS256-only mode.
HUB_JWT_PUBLIC_KEY_PATH=
HUB_JWT_PRIVATE_KEY_PATH=
HUB_JWT_KEY_ID=hub-rs256-v1
# ISO date; HS256 tokens issued before this time remain valid. Empty = no fallback.
HUB_HS256_TRANSITION_UNTIL=

# ─── Phase B: Worker Join Tokens ─────────────────────────────────────
HUB_JOIN_TOKEN_EXPIRY=24h
HUB_JOIN_TOKEN_MAX=100

# ─── Phase B / F: SSH Deployment ─────────────────────────────────────
HUB_SSH_DEFAULT_PORT=22
HUB_SSH_TIMEOUT=60000

# ─── Phase D: Model Repository ───────────────────────────────────────
HUB_MODEL_REPO_DIR=./data/model-repo
HUB_MODEL_MAX_SIZE=5368709120

# ─── Phase E: Bundle / Images ────────────────────────────────────────
HUB_BUNDLE_IMAGES_DIR=./data/bundle/images
HUB_BUNDLE_DIR=./data/bundle

# ─── Phase F: Deployment & Encryption ────────────────────────────────
# Base URL DA workers use to reach Hub (for `curl | docker load`).
HUB_EXTERNAL_URL=http://localhost:22000
# AES-256-GCM master key for encrypting SSH private keys at rest.
# Must be >=32 chars high-entropy; falls back to JWT_SECRET if unset (NOT recommended for prod).
HUB_DATA_KEY=
