# DeepAnalyze Configuration
# Copy this file to .env and customize for your setup.

# Server
PORT=21000
NODE_ENV=development

# Data directory (stores wiki files, uploaded documents)
DATA_DIR=data

# Model configuration path
MODEL_CONFIG=config/default.yaml

# LLM endpoint (OpenAI-compatible)
# For Ollama: http://localhost:11434/v1
# For OpenAI: https://api.openai.com/v1
# For other compatible services, set the appropriate URL
LLM_ENDPOINT=http://localhost:11434/v1

# Default model name
LLM_MODEL=qwen2.5-14b

# API key (if using a service that requires one)
# LLM_API_KEY=sk-...

# =============================================================================
# PostgreSQL (required)
# DeepAnalyze needs a PostgreSQL instance with the pgvector extension.
# zhparser (Chinese full-text search) is OPTIONAL: if absent, the app still
# starts and FTS falls back to the default tokenizer (poorer Chinese word
# segmentation). So any PG with pgvector works — Docker, native install, or a
# cloud provider (e.g. Neon, Supabase) that supports pgvector.
# =============================================================================
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=deepanalyze
PG_USER=deepanalyze
PG_PASSWORD=deepanalyze_dev

# =============================================================================
# MiniMax AI (optional — for multimodal capabilities)
# Docs: https://www.minimaxi.com/document
# =============================================================================
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_group_id_here

# =============================================================================
# Server connection (Worker mode — leave empty for standalone mode)
# When DA_SERVER_URL is set, this DA instance operates as a Worker that
# connects to a central Server (deepanalyze-hub) for config sync,
# marketplace features, and user authentication.
# =============================================================================
# DA_SERVER_URL=https://hub.example.com
# DA_WORKER_ID=auto
# DA_WORKER_TOKEN=
