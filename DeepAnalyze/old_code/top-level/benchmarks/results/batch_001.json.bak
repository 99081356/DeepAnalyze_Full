          "command": "python3 << 'EOF'\nimport pandas as pd\n\nfilepath = \"original/e93435e3-fe35-43e7-8d3b-12bf38bf4d47/department_hierarchy.xlsx\"\n\n# 1. 技术研发部(D001)的员工\ndf_emp = pd.read_excel(filepath, sheet_name='员工表')\nd001_employees = df_emp[df_emp['dept_id'] == 'D001']\nprint(f\"=== 技术研发部(D001)员工总数: {len(d001_employees)} ===\")\nprint(d001_employees[['name', 'position']].to_string(index=False))\n\nprint(\"\\n\")\n\n# 2. 哪些部门有正在进行中的项目\ndf_proj = pd.read_excel(filepath, sheet_name='项目表')\ndf_dept = pd.read_excel(filepath, sheet_name='部门表')\n\nactive_projects = df_proj[df_proj['status'] == '进行中']\nprint(f\"=== 状态为'进行中'的项目 ===\")\nprint(active_projects[['project_id', 'project_name', 'dept_id', 'status']].to_string(index=False))\n\n# 关联部门名称\nactive_with_dept = active_projects.merge(df_dept[['dept_id', 'dept_name']], on='dept_id', how='left')\nprint(f\"\\n=== 有进行中项目的部门 ===\")\ndepts_with_active = active_with_dept[['dept_id', 'dept_name']].drop_duplicates()\nprint(depts_with_dept.to_string(index=False))\n\n# 完整展示进行中项目+部门\nprint(f\"\\n=== 进行中项目详情（含部门名称） ===\")\nprint(active_with_dept[['project_id', 'project_name', 'dept_id', 'dept_name', 'start_date', 'end_date', 'budget']].to_string(index=False))\nEOF\n"
