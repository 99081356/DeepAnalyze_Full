          "command": "python3 << 'PYEOF'\nimport openpyxl\nfrom collections import defaultdict\n\n# ========== 读取订单表 ==========\nwb1 = openpyxl.load_workbook('original/e93435e3-fe35-43e7-8d3b-12bf38bf4d47/crossref_orders.xlsx')\nws1 = wb1.active\n\norders = []\nfor row in ws1.iter_rows(min_row=2, values_only=True):\n    orders.append({\n        'order_id': row[0],\n        'employee_id': row[1],\n        'customer_name': row[2],\n        'product': row[3],\n        'quantity': row[4],\n        'unit_price': row[5],\n        'total': row[6],\n        'order_date': row[7]\n    })\n\nprint(f\"订单总数: {len(orders)}\")\n\n# ========== 读取员工表 ==========\nwb2 = openpyxl.load_workbook('original/e93435e3-fe35-43e7-8d3b-12bf38bf4d47/department_hierarchy.xlsx')\nws_emp = wb2['员工表']\n\nemployees = {}\nfor row in ws_emp.iter_rows(min_row=2, values_only=True):\n    employees[row[0]] = {\n        'name': row[1],\n        'dept_id': row[2],\n        'position': row[3],\n        'salary': row[4],\n        'hire_date': row[5]\n    }\n\n# ========== 读取部门表 ==========\nws_dept = wb2['部门表']\ndepartments = {}\nfor row in ws_dept.iter_rows(min_row=2, values_only=True):\n    departments[row[0]] = {\n        'dept_name': row[1],\n        'manager': row[2],\n        'budget': row[3],\n        'location': row[4]\n    }\n\nprint(f\"员工总数: {len(employees)}\")\nprint(f\"部门总数: {len(departments)}\")\n\n# ========== 问题1：员工E0001的所有订单总金额 ==========\ne0001_orders = [o for o in orders if o['employee_id'] == 'E0001']\ne0001_total = sum(o['total'] for o in e0001_orders)\n\nprint(f\"\\n{'='*60}\")\nprint(f\"问题1：员工E0001（{employees['E0001']['name']}）的订单详情\")\nprint(f\"{'='*60}\")\nprint(f\"部门: {departments[employees['E0001']['dept_id']]['dept_name']}\")\nprint(f\"职位: {employees['E0001']['position']}\")\nprint(f\"订单数量: {len(e0001_orders)}\")\nprint(f\"\\n订单明细:\")\nprint(f\"{'订单ID':<14} {'客户':<12} {'产品':<10} {'数量':>4} {'单价':>12} {'金额':>12} {'日期'}\")\nprint(\"-\" * 80)\nfor o in e0001_orders:\n    print(f\"{o['order_id']:<14} {o['customer_name']:<12} {o['product']:<10} {o['quantity']:>4} {o['unit_price']:>12.2f} {o['total']:>12.2f} {o['order_date']}\")\nprint(\"-\" * 80)\nprint(f\"{'总计':<14} {'':<12} {'':<10} {sum(o['quantity'] for o in e0001_orders):>4} {'':>12} {e0001_total:>12.2f}\")\n\n# ========== 问题2：哪个部门的员工产生的订单总额最高 ==========\ndept_order_totals = defaultdict(float)\ndept_order_counts = defaultdict(int)\ndept_employee_counts = defaultdict(set)\n\nfor o in orders:\n    eid = o['employee_id']\n    if eid in employees:\n        did = employees[eid]['dept_id']\n        dept_order_totals[did] += o['total']\n        dept_order_counts[did] += 1\n        dept_employee_counts[did].add(eid)\n\nprint(f\"\\n{'='*60}\")\nprint(f\"问题2：各部门订单总额排名\")\nprint(f\"{'='*60}\")\nprint(f\"{'排名':<4} {'部门ID':<8} {'部门名称':<14} {'订单数':>6} {'员工数':>6} {'订单总额':>16}\")\nprint(\"-\" * 60)\n\nsorted_depts = sorted(dept_order_totals.items(), key=lambda x: x[1], reverse=True)\nfor i, (did, total) in enumerate(sorted_depts, 1):\n    dname = departments[did]['dept_name']\n    cnt = dept_order_counts[did]\n    ecnt = len(dept_employee_counts[did])\n    print(f\"{i:<4} {did:<8} {dname:<14} {cnt:>6} {ecnt:>6} {total:>16.2f}\")\n\nprint(\"-\" * 60)\ngrand_total = sum(dept_order_totals.values())\nprint(f\"{'合计':<4} {'':<8} {'':<14} {sum(dept_order_counts.values()):>6} {sum(len(v) for v in dept_employee_counts.values()):>6} {grand_total:>16.2f}\")\n\ntop_dept = sorted_depts[0]\nprint(f\"\\n✅ 订单总额最高的部门: {departments[top_dept[0]]['dept_name']}（{top_dept[0]}），总额: {top_dept[1]:.2f} 元\")\n\nPYEOF\n"
        },
        "status": "completed",
        "output_preview": "{\"exitCode\":0,\"output\":\"订单总数: 500\\n员工总数: 50\\n部门总数: 6\\n\\n============================================================\\n问题1：员工E0001（员工_1）的订单详情\\n=========================================================="
      },
