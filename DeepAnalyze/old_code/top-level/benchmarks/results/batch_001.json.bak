        "tool": "bash",
        "input": {
          "command": "python3 << 'EOF'\nimport pandas as pd\n\ndf = pd.read_csv('original/e93435e3-fe35-43e7-8d3b-12bf38bf4d47/unicode_data.csv')\n\nprint(\"=== 1) 记录总数 ===\")\nprint(f\"总记录数: {len(df)}\")\nprint(f\"列名: {list(df.columns)}\")\n\nprint(\"\\n=== 2) multilingual 列的所有不同值 ===\")\nif 'multilingual' in df.columns:\n    unique_vals = df['multilingual'].unique()\n    print(f\"不同值的数量: {len(unique_vals)}\")\n    for i, val in enumerate(unique_vals):\n        print(f\"  [{i+1}] {val}\")\nelse:\n    print(\"未找到 multilingual 列\")\n    # 模糊匹配\n    for col in df.columns:\n        if 'multi' in col.lower() or 'lang' in col.lower():\n            print(f\"  可能的列: {col}\")\n\nprint(\"\\n=== 3) 检查日文、韩文、阿拉伯文 ===\")\nif 'multilingual' in df.columns:\n    import re\n    # 日文: Hiragana + Katakana ranges\n    japanese_pattern = re.compile(r'[\\u3040-\\u309F\\u30A0-\\u30FF\\uFF65-\\uFF9F]')\n    # 韩文: Hangul\n    korean_pattern = re.compile(r'[\\uAC00-\\uD7AF\\u1100-\\u11FF\\u3130-\\u318F]')\n    # 阿拉伯文\n    arabic_pattern = re.compile(r'[\\u0600-\\u06FF\\u0750-\\u077F\\u08A0-\\u08FF]')\n    \n    all_text = df['multilingual'].dropna().astype(str).str.cat(sep=' ')\n    \n    has_japanese = bool(japanese_pattern.search(all_text))\n    has_korean = bool(korean_pattern.search(all_text))\n    has_arabic = bool(arabic_pattern.search(all_text))\n    \n    print(f\"包含日文: {'是' if has_japanese else '否'}\")\n    print(f\"包含韩文: {'是' if has_korean else '否'}\")\n    print(f\"包含阿拉伯文: {'是' if has_arabic else '否'}\")\n    \n    if has_japanese:\n        jp_rows = df[df['multilingual'].astype(str).str.contains(r'[\\u3040-\\u309F\\u30A0-\\u30FF]', na=False)]\n        print(f\"  日文所在行示例: {jp_rows['multilingual'].head(3).tolist()}\")\n    if has_korean:\n        kr_rows = df[df['multilingual'].astype(str).str.contains(r'[\\uAC00-\\uD7AF]', na=False)]\n        print(f\"  韩文所在行示例: {kr_rows['multilingual'].head(3).tolist()}\")\n    if has_arabic:\n        ar_rows = df[df['multilingual'].astype(str).str.contains(r'[\\u0600-\\u06FF]', na=False)]\n        print(f\"  阿拉伯文所在行示例: {ar_rows['multilingual'].head(3).tolist()}\")\n\nprint(\"\\n=== 文件前几行预览 ===\")\nprint(df.to_string())\nEOF\n"
        },
