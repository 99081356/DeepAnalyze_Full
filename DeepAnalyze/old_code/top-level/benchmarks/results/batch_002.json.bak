          "command": "python3 << 'PYEOF'\nimport csv\nimport io\n\n# 读取原始文件\nwith open('original/e93435e3-fe35-43e7-8d3b-12bf38bf4d47/employee_basic.csv', 'r', encoding='utf-8') as f:\n    original_content = f.read()\n\n# 读取parsed.md\nwith open('wiki/e93435e3-fe35-43e7-8d3b-12bf38bf4d47/documents/b314913a-0231-4212-9384-4223e496c158/parsed.md', 'r', encoding='utf-8') as f:\n    parsed_content = f.read()\n\n# 解析原始CSV\norig_reader = csv.reader(io.StringIO(original_content))\norig_rows = list(orig_reader)\n\n# 解析parsed.md中的CSV (去掉开头的注释行，如果有)\nparsed_lines = parsed_content.strip().split('\\n')\n# parsed.md 内容就是纯CSV数据\nparsed_reader = csv.reader(io.StringIO(parsed_content))\nparsed_rows = list(parsed_reader)\n\nprint(\"=\" * 60)\nprint(\"对比结果：原始 employee_basic.csv vs parsed.md\")\nprint(\"=\" * 60)\n\n# 1. 行数对比\nprint(f\"\\n【1. 行数对比】\")\nprint(f\"  原始CSV行数: {len(orig_rows)} 行 (含表头)\")\nprint(f\"  parsed.md行数: {len(parsed_rows)} 行 (含表头)\")\nprint(f\"  数据行: 原始={len(orig_rows)-1}, parsed={len(parsed_rows)-1}\")\nif len(orig_rows) == len(parsed_rows):\n    print(\"  ✅ 行数完全匹配\")\nelse:\n    print(f\"  ❌ 行数不一致，差异: {len(orig_rows) - len(parsed_rows)} 行\")\n\n# 2. 列名对比\nprint(f\"\\n【2. 列名对比】\")\norig_headers = orig_rows[0] if orig_rows else []\nparsed_headers = parsed_rows[0] if parsed_rows else []\nprint(f\"  原始列名 ({len(orig_headers)}列): {orig_headers}\")\nprint(f\"  parsed列名 ({len(parsed_headers)}列): {parsed_headers}\")\nif orig_headers == parsed_headers:\n    print(\"  ✅ 列名完全一致\")\nelse:\n    print(\"  ❌ 列名存在差异\")\n    for i, (o, p) in enumerate(zip(orig_headers, parsed_headers)):\n        if o != p:\n            print(f\"     第{i}列: 原始='{o}', parsed='{p}'\")\n\n# 3. 数据内容逐行逐格对比\nprint(f\"\\n【3. 数据内容逐行对比】\")\ndiff_count = 0\ndiff_details = []\nmax_rows = max(len(orig_rows), len(parsed_rows))\nfor row_idx in range(max_rows):\n    if row_idx >= len(orig_rows):\n        diff_count += 1\n        diff_details.append(f\"  行{row_idx}: parsed.md有额外行: {parsed_rows[row_idx]}\")\n        continue\n    if row_idx >= len(parsed_rows):\n        diff_count += 1\n        diff_details.append(f\"  行{row_idx}: 原始CSV有额外行: {orig_rows[row_idx]}\")\n        continue\n    \n    orig_row = orig_rows[row_idx]\n    parsed_row = parsed_rows[row_idx]\n    \n    max_cols = max(len(orig_row), len(parsed_row))\n    for col_idx in range(max_cols):\n        if col_idx >= len(orig_row):\n            diff_count += 1\n            diff_details.append(f\"  [{row_idx},{col_idx}]: parsed.md有额外列值: '{parsed_row[col_idx]}'\")\n        elif col_idx >= len(parsed_row):\n            diff_count += 1\n            diff_details.append(f\"  [{row_idx},{col_idx}]: 原始CSV有额外列值: '{orig_row[col_idx]}'\")\n        elif orig_row[col_idx] != parsed_row[col_idx]:\n            diff_count += 1\n            diff_details.append(f\"  [{row_idx},{col_idx}]: 原始='{orig_row[col_idx]}', parsed='{parsed_row[col_idx]}'\")\n\nif diff_count == 0:\n    print(\"  ✅ 所有数据单元格完全一致，无任何差异\")\nelse:\n    print(f\"  ❌ 共发现 {diff_count} 处差异:\")\n    for d in diff_details[:20]:  # 最多显示20条\n        print(d)\n    if len(diff_details) > 20:\n        print(f\"  ... 还有 {len(diff_details) - 20} 处差异\")\n\n# 4. 字节数对比\nprint(f\"\\n【4. 文件大小对比】\")\nprint(f\"  原始CSV字节数: {len(original_content.encode('utf-8'))}\")\nprint(f\"  parsed.md字节数: {len(parsed_content.encode('utf-8'))}\")\n\n# 5. 编码检查\nprint(f\"\\n【5. 换行符检查】\")\norig_crlf = original_content.count('\\r\\n')\norig_lf = original_content.count('\\n') - orig_crlf\nparsed_crlf = parsed_content.count('\\r\\n')\nparsed_lf_only = parsed_content.count('\\n') - parsed_crlf\nprint(f\"  原始CSV: CRLF={orig_crlf}, LF={orig_lf}\")\nprint(f\"  parsed.md: CRLF={parsed_crlf}, LF-only={parsed_lf_only}\")\n\nPYEOF"
        },
