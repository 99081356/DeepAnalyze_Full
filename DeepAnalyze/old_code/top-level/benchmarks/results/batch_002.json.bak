          "command": "python3 << 'PYEOF'\nimport csv\nimport io\nimport hashlib\n\n# 1. 读取原始CSV文件\nwith open('original/e93435e3-fe35-43e7-8d3b-12bf38bf4d47/employee_basic.csv', 'r', encoding='utf-8') as f:\n    original_content = f.read()\n\n# 2. 读取parsed.md（预处理后的数据）\nwith open('wiki/e93435e3-fe35-43e7-8d3b-12bf38bf4d47/documents/b314913a-0231-4212-9384-4223e496c158/parsed.md', 'r', encoding='utf-8') as f:\n    parsed_content = f.read()\n\n# MD5哈希对比\norig_md5 = hashlib.md5(original_content.encode('utf-8')).hexdigest()\nparsed_md5 = hashlib.md5(parsed_content.encode('utf-8')).hexdigest()\n\nprint(\"=\" * 65)\nprint(\"  employee_basic.csv 数据一致性验证报告\")\nprint(\"=\" * 65)\n\nprint(f\"\\n【MD5哈希校验】\")\nprint(f\"  原始文件 MD5:   {orig_md5}\")\nprint(f\"  parsed.md MD5:  {parsed_md5}\")\nif orig_md5 == parsed_md5:\n    print(\"  ✅ MD5完全一致，文件内容100%相同\")\nelse:\n    print(\"  ⚠️ MD5不同，但需进一步逐字节比对\")\n\n# 字节级对比\norig_bytes = original_content.encode('utf-8')\nparsed_bytes = parsed_content.encode('utf-8')\n\nif orig_bytes == parsed_bytes:\n    print(f\"\\n  ✅ 逐字节对比完全一致 ({len(orig_bytes)} bytes)\")\nelse:\n    # 找出第一个不同字节的位置\n    for i in range(min(len(orig_bytes), len(parsed_bytes))):\n        if orig_bytes[i] != parsed_bytes[i]:\n            print(f\"\\n  ❌ 首个差异字节位置: {i}\")\n            print(f\"     原始: 0x{orig_bytes[i]:02x} ({chr(orig_bytes[i]) if 32 <= orig_bytes[i] < 127 else '?'})\")\n            print(f\"     parsed: 0x{parsed_bytes[i]:02x} ({chr(parsed_bytes[i]) if 32 <= parsed_bytes[i] < 127 else '?'})\")\n            # 打印前后10字节的上下文\n            start = max(0, i-10)\n            print(f\"     原始上下文: ...{orig_bytes[start:i+10]}...\")\n            print(f\"     parsed上下文: ...{parsed_bytes[start:i+10]}...\")\n            break\n\n# 解析数据做结构化对比\norig_reader = csv.reader(io.StringIO(original_content))\norig_rows = list(orig_reader)\n\nparsed_reader = csv.reader(io.StringIO(parsed_content))\nparsed_rows = list(parsed_reader)\n\nprint(f\"\\n{'='*65}\")\nprint(f\"  结构化数据对比\")\nprint(f\"{'='*65}\")\n\nprint(f\"\\n┌─────────────────────────────────────────────────────────┐\")\nprint(f\"│ 对比项              │ 原始CSV    │ 预处理后(parsed.md) │ 结果\")\nprint(f\"├─────────────────────────────────────────────────────────┤\")\nprint(f\"│ 总行数(含表头)      │ {len(orig_rows):>10} │ {len(parsed_rows):>19} │ {'✅ 一致' if len(orig_rows)==len(parsed_rows) else '❌ 不一致'}\")\nprint(f\"│ 数据行数            │ {len(orig_rows)-1:>10} │ {len(parsed_rows)-1:>19} │ {'✅ 一致' if len(orig_rows)-1==len(parsed_rows)-1 else '❌ 不一致'}\")\nprint(f\"│ 列数                │ {len(orig_rows[0]):>10} │ {len(parsed_rows[0]):>19} │ {'✅ 一致' if len(orig_rows[0])==len(parsed_rows[0]) else '❌ 不一致'}\")\nprint(f\"│ 文件大小(bytes)     │ {len(orig_bytes):>10} │ {len(parsed_bytes):>19} │ {'✅ 一致' if len(orig_bytes)==len(parsed_bytes) else '❌ 不一致'}\")\n\nheaders_match = orig_rows[0] == parsed_rows[0]\nprint(f\"│ 列名完全匹配        │ {'—':>10} │ {'—':>19} │ {'✅ 一致' if headers_match else '❌ 不一致'}\")\n\n# 逐单元格对比\ncell_diffs = 0\nfor r in range(1, min(len(orig_rows), len(parsed_rows))):\n    for c in range(min(len(orig_rows[r]), len(parsed_rows[r]))):\n        if orig_rows[r][c] != parsed_rows[r][c]:\n            cell_diffs += 1\n\nprint(f\"│ 数据单元格差异      │ {'—':>10} │ {'—':>19} │ {'✅ 0差异' if cell_diffs==0 else f'❌ {cell_diffs}处'}\")\nprint(f\"└─────────────────────────────────────────────────────────┘\")\n\nprint(f\"\\n列名详情:\")\nfor i, (o, p) in enumerate(zip(orig_rows[0], parsed_rows[0])):\n    status = \"✅\" if o == p else \"❌\"\n    print(f\"  {status} 第{i+1}列: '{o}' {'=' if o==p else '≠'} '{p}'\")\n\n# 抽样数据验证（首行、末行、中间行）\nprint(f\"\\n抽样数据验证:\")\nsamples = [1, 25, 50]  # 数据行索引\nfor s in samples:\n    if s < len(orig_rows) and s < len(parsed_rows):\n        match = orig_rows[s] == parsed_rows[s]\n        print(f\"  {'✅' if match else '❌'} 第{s}行(EMP{s:04d}): {orig_rows[s]}\")\n\nprint(f\"\\n{'='*65}\")\nprint(f\"  最终结论\")\nprint(f\"{'='*65}\")\nif orig_bytes == parsed_bytes and cell_diffs == 0 and headers_match:\n    print(f\"  ✅ 预处理后的数据与原始数据完全一致\")\n    print(f\"     - 行数匹配: 51行(含表头) = 50条数据记录\")\n    print(f\"     - 列名相同: {orig_rows[0]}\")\n    print(f\"     - 所有单元格值逐个匹配，零差异\")\n    print(f\"     - 文件MD5哈希值相同，字节级一致\")\nelse:\n    print(f\"  ❌ 存在差异，请检查上述详情\")\n\nPYEOF"
