# DeepAnalyze Intranet Deployment Environment
#
# Copy this file to .env and modify as needed
# Usually no changes needed — just edit config/default.yaml for your LLM
#

# Frontend Web UI port (user access point)
FRONTEND_PORT=21000

# PostgreSQL
PG_DATABASE=deepanalyze
PG_USER=deepanalyze
PG_PASSWORD=deepanalyze_dev
