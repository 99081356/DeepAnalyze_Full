{
  "name": "deepanalyze-hub",
  "version": "0.1.0",
  "description": "DeepAnalyze Hub — central server for Worker management, config distribution, and resource marketplace",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "start": "bun run src/main.ts",
    "db:migrate": "bun run src/store/migrate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.3",
    "bcrypt": "^5.1.0",
    "dotenv": "^17.4.2",
    "hono": "^4.7.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.14.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/bun": "^1.2.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.0"
  }
}
