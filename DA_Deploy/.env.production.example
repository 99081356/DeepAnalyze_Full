# =============================================================================
# DeepAnalyze Hub - 生产环境变量模板
# =============================================================================
# 用法：
#   cp .env.production.example .env
#   # 编辑 .env，所有标注「必填」的项必须设置
#   # 推荐用 scripts/generate-secrets.sh 自动生成所有密钥
#
# 强制项（compose 用 ${VAR:?...} 校验，缺失会拒绝启动）：
#   PG_PASSWORD / JWT_SECRET / JWT_REFRESH_SECRET /
#   ADMIN_INIT_PASSWORD / HUB_EXTERNAL_URL / HUB_DATA_KEY
# =============================================================================

# ─── Server ──────────────────────────────────────────────────────────────────
# Hub 监听端口
PORT=22000
# Hub 镜像（在线构建忽略；离线部署填 build-bundle.sh 打出的 tag）
HUB_IMAGE=deepanalyze-hub:latest

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
# 数据库名 / 用户名保持默认即可，密码必须强随机
PG_DATABASE=deepanalyze_hub
PG_USER=deepanalyze_hub
PG_PASSWORD=                              # 【必填】32+ 字符强随机，generate-secrets.sh 生成

# ─── JWT / Auth ─────────────────────────────────────────────────────────────
JWT_SECRET=                               # 【必填】32+ 字符强随机
JWT_REFRESH_SECRET=                       # 【必填】32+ 字符强随机，与 JWT_SECRET 不同
JWT_EXPIRY=7d
WORKER_TOKEN_EXPIRY=30d

# Worker join token（Hub 控制台发放给 worker 的注册令牌）
HUB_JOIN_TOKEN_EXPIRY=24h
HUB_JOIN_TOKEN_MAX=100

# JWT RS256 keypair —— generate-secrets.sh 生成到 ./secrets/keys/
# 通过卷挂载进容器；compose 内固定路径，无需在此设置
HUB_JWT_KEY_ID=hub-rs256-v1

# ─── 初始管理员密码 ─────────────────────────────────────────────────────────
# 首次启动 migration 008 用此值 seed admin 账号。
# 生产环境必须设置强密码；登录后建议在控制台修改。
# 缺失则回退到弱口令 admin123（dev 兼容，生产禁止）。
ADMIN_INIT_PASSWORD=                      # 【必填】16+ 字符强随机

# ─── 数据加密 ───────────────────────────────────────────────────────────────
# AES-256-GCM 主密钥，用于加密存储 SSH 私钥等敏感数据。
# 必须 >=32 字符高熵；丢失会导致已加密数据无法解密，请妥善备份。
HUB_DATA_KEY=                             # 【必填】32+ 字符强随机

# ─── SSH 部署（Worker 远程部署模式）─────────────────────────────────────────
HUB_SSH_DEFAULT_PORT=22
HUB_SSH_TIMEOUT=60000

# ─── Local Docker 部署模式（Worker 与 Hub 同机）─────────────────────────────
# Hub 通过 docker.sock 在本机拉起 worker 容器时用的镜像名。
# 默认值与你 docker load 的镜像一致，通常无需修改。
HUB_DA_IMAGE=deepanalyze/da:latest
HUB_DA_PG_IMAGE=pgvector/pgvector:pg16

# ─── 外部访问 URL ───────────────────────────────────────────────────────────
# DA Worker 用此 URL 回访 Hub（拉 bundle / 验 SSO ticket）。
# 必须是 worker 能访问到的地址，例如 http://<内网IP>:22000 或 https://hub.internal
HUB_EXTERNAL_URL=http://CHANGE_ME:22000   # 【必填】替换为真实可达地址

# ─── 存储 / 模型仓库 ────────────────────────────────────────────────────────
HUB_MODEL_MAX_SIZE=5368709120             # 单个模型文件上限 5GB

# ─── 备份 ───────────────────────────────────────────────────────────────────
# Hub 内置备份保留策略（控制台触发的备份）；外置脚本备份见 scripts/backup.sh
HUB_BACKUP_RETENTION_DAYS=30

# ─── Docker Registry（可选）──────────────────────────────────────────────────
# 自建 registry 地址（如 harbor.example.com/da）。留空使用默认镜像源。
HUB_DOCKER_REGISTRY=
